{
  "openapi": "3.0.3",
  "info": {
    "title": "GitFlame CodePilot Backend",
    "version": "0.5.0",
    "description": "Secure GitFlame connection, repository data, asynchronous Issue-to-Plan, code-generation, and recommendation service integration."
  },
  "servers": [{"url": "http://localhost:8000"}],
  "tags": [
    {"name": "health"},
    {"name": "auth"},
    {"name": "integrations"},
    {"name": "agent tasks"},
    {"name": "issue workflow"},
    {"name": "recommendations"}
  ],
  "paths": {
    "/health": {"get": {"tags": ["health"], "summary": "Backend health check", "responses": {"200": {"description": "Healthy"}}}},
    "/ready": {"get": {"tags": ["health"], "summary": "Check storage, Redis, and Agent Engine readiness", "responses": {"200": {"description": "All configured dependencies are ready"}, "503": {"description": "At least one dependency is unavailable"}}}},
    "/auth/gitflame/session": {
      "post": {
        "tags": ["auth"],
        "summary": "Validate a GitFlame token and create an HttpOnly application session cookie",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["access_token"], "properties": {"access_token": {"type": "string", "format": "password"}}}}}},
        "responses": {
          "201": {"description": "Application session created", "headers": {"Set-Cookie": {"schema": {"type": "string"}, "description": "HttpOnly session cookie; GitFlame access token is not stored in the browser."}}, "content": {"application/json": {"schema": {"type": "object", "properties": {"user": {"$ref": "#/components/schemas/AppUser"}, "session_expires_at": {"type": "string", "format": "date-time"}}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "422": {"$ref": "#/components/responses/ValidationError"},
          "503": {"description": "GitFlame client is not configured"}
        }
      }
    },
    "/auth/session": {"delete": {"tags": ["auth"], "summary": "Revoke the current application session", "responses": {"204": {"description": "Session revoked"}, "401": {"$ref": "#/components/responses/Unauthorized"}}}},
    "/integrations/gitflame/connections": {
      "post": {
        "tags": ["integrations"],
        "summary": "Create or update a per-user GitFlame repository connection",
        "description": "The backend validates the token, resolves repository metadata from repo_url when repository.id is omitted, stores only AES-GCM ciphertext/nonce/key_version, and returns a response without token material. If no application session cookie exists, this endpoint creates one from the same GitFlame token.",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GitFlameConnectionRequest"}}}},
        "responses": {
          "201": {"description": "Connection saved", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GitFlameConnection"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "422": {"$ref": "#/components/responses/ValidationError"},
          "503": {"description": "Credential cipher or GitFlame client is not configured"}
        }
      }
    },
    "/integrations/gitflame/connections/{id}": {
      "put": {
        "tags": ["integrations"],
        "summary": "Reconnect an existing GitFlame repository connection with a new token",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GitFlameConnectionRequest"}}}},
        "responses": {"200": {"description": "Connection updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GitFlameConnection"}}}}, "400": {"$ref": "#/components/responses/BadRequest"}, "401": {"$ref": "#/components/responses/Unauthorized"}, "404": {"$ref": "#/components/responses/NotFound"}, "422": {"$ref": "#/components/responses/ValidationError"}}
      },
      "delete": {
        "tags": ["integrations"],
        "summary": "Revoke a GitFlame repository connection token",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"200": {"description": "Connection revoked", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GitFlameConnection"}}}}, "401": {"$ref": "#/components/responses/Unauthorized"}, "404": {"$ref": "#/components/responses/NotFound"}}
      }
    },
    "/integrations/gitflame/connections/{id}/tree": {
      "get": {
        "tags": ["integrations"],
        "summary": "Read the connected repository tree through the backend",
        "parameters": [
          {"$ref": "#/components/parameters/ConnectionID"},
          {"name": "ref", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Branch, tag, or commit. Defaults to the connection's default branch."}
        ],
        "responses": {
          "200": {"description": "Repository tree", "content": {"application/json": {"schema": {"type": "object", "properties": {"repository_id": {"type": "string"}, "ref": {"type": "string"}, "tree": {"type": "array", "items": {"$ref": "#/components/schemas/GitFlameTreeEntry"}}}}}}},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"},
          "502": {"description": "GitFlame API error"}
        }
      }
    },
    "/integrations/gitflame/connections/{id}/files": {
      "get": {
        "tags": ["integrations"],
        "summary": "Read connected repository files with raw content through the backend",
        "description": "Fetches .ai.yml, applies analysis include/exclude/max_files rules, downloads raw file contents from GitFlame with the saved per-user connection token, and returns repository_files ready for Agent Engine.",
        "parameters": [
          {"$ref": "#/components/parameters/ConnectionID"},
          {"name": "ref", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Branch, tag, or commit. Defaults to the connection's default branch."}
        ],
        "responses": {
          "200": {"description": "Repository files with content", "content": {"application/json": {"schema": {"type": "object", "properties": {"repository_id": {"type": "string"}, "ref": {"type": "string"}, "yaml_config": {"type": "string"}, "repository_files": {"type": "array", "items": {"$ref": "#/components/schemas/RepositoryFile"}}}}}}},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"},
          "502": {"description": "GitFlame API error"}
        }
      }
    },
    "/integrations/gitflame/connections/{id}/issues": {
      "get": {
        "tags": ["integrations"],
        "summary": "List open issues from the connected repository through the backend",
        "parameters": [{"$ref": "#/components/parameters/ConnectionID"}],
        "responses": {
          "200": {"description": "Open repository issues", "content": {"application/json": {"schema": {"type": "object", "properties": {"repository_id": {"type": "string"}, "issues": {"type": "array", "items": {"$ref": "#/components/schemas/Issue"}}}}}}},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"},
          "502": {"description": "GitFlame API error"}
        }
      }
    },
    "/integrations/gitflame/issues/analyze": {
      "post": {
        "tags": ["issue workflow"],
        "summary": "Validate an issue and enqueue plan generation",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/IssueAnalyzeRequest"}}}},
        "responses": {
          "202": {"description": "Agent task queued", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/IssueAnalyzeResponse"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "422": {"$ref": "#/components/responses/ValidationError"}
        }
      }
    },
    "/integrations/gitflame/webhooks/issues": {
      "post": {
        "tags": ["integrations"],
        "summary": "Accept a GitFlame issue webhook and enqueue plan generation",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GitFlameIssueWebhook"}}}},
        "responses": {
          "202": {"description": "Agent task queued", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/IssueAnalyzeResponse"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "422": {"$ref": "#/components/responses/ValidationError"},
          "503": {"description": "GitFlame client or downstream service unavailable"}
        }
      }
    },
    "/ai/tasks/{taskId}": {
      "get": {
        "tags": ["agent tasks"], "summary": "Get asynchronous generation status",
        "parameters": [{"$ref": "#/components/parameters/TaskID"}],
        "responses": {"200": {"description": "Task state", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AgentTask"}}}}, "404": {"$ref": "#/components/responses/NotFound"}}
      }
    },
    "/ai/tasks/{taskId}/retry": {"post": {"tags": ["agent tasks"], "summary": "Retry a task that failed with a temporary Agent Engine error", "parameters": [{"$ref": "#/components/parameters/TaskID"}], "responses": {"202": {"description": "Replacement task queued"}, "404": {"$ref": "#/components/responses/NotFound"}, "422": {"$ref": "#/components/responses/ValidationError"}}}},
    "/ai/issues/{id}/plan": {"get": {"tags": ["issue workflow"], "summary": "Get the latest generated plan", "parameters": [{"$ref": "#/components/parameters/IssueID"}], "responses": {"200": {"description": "Latest plan"}, "404": {"$ref": "#/components/responses/NotFound"}, "409": {"description": "Plan is not ready"}}}},
    "/ai/issues/{id}/approve": {"post": {"tags": ["issue workflow"], "summary": "Approve the plan and enqueue code generation", "parameters": [{"$ref": "#/components/parameters/IssueID"}], "requestBody": {"required": false, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ApprovePlanRequest"}}}}, "responses": {"202": {"description": "Code generation task queued"}, "400": {"$ref": "#/components/responses/BadRequest"}, "404": {"$ref": "#/components/responses/NotFound"}, "422": {"$ref": "#/components/responses/ValidationError"}}}},
    "/ai/issues/{id}/code-generation": {"get": {"tags": ["issue workflow"], "summary": "Get code generation status and generated files contract", "parameters": [{"$ref": "#/components/parameters/IssueID"}], "responses": {"200": {"description": "Code generation task state", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AgentTask"}}}}, "404": {"$ref": "#/components/responses/NotFound"}, "409": {"description": "Code generation has not started"}}}},
    "/ai/issues/{id}/gitflame/apply": {"post": {"tags": ["integrations"], "summary": "Apply generated files to GitFlame and create a pull request", "parameters": [{"$ref": "#/components/parameters/IssueID"}], "responses": {"200": {"description": "Generated files were applied and PR metadata was saved"}, "401": {"$ref": "#/components/responses/Unauthorized"}, "404": {"$ref": "#/components/responses/NotFound"}, "409": {"description": "Generated files are not ready"}, "502": {"description": "GitFlame API error"}, "503": {"description": "GitFlame client is not configured or unavailable"}}}},
    "/ai/issues/{id}/correct": {
      "post": {
        "tags": ["issue workflow"], "summary": "Enqueue regeneration with feedback and the previous plan", "parameters": [{"$ref": "#/components/parameters/IssueID"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["feedback"], "properties": {"feedback": {"type": "string"}}}}}},
        "responses": {"202": {"description": "Correction task queued"}, "400": {"$ref": "#/components/responses/BadRequest"}, "404": {"$ref": "#/components/responses/NotFound"}, "422": {"$ref": "#/components/responses/ValidationError"}}
      }
    },
    "/ai/issues/{id}/reject": {"post": {"tags": ["issue workflow"], "summary": "Reject a plan", "parameters": [{"$ref": "#/components/parameters/IssueID"}], "responses": {"200": {"description": "Plan rejected"}, "404": {"$ref": "#/components/responses/NotFound"}, "422": {"$ref": "#/components/responses/ValidationError"}}}},
    "/integrations/gitflame/repositories/{id}/recommendations/analyze": {"post": {"tags": ["recommendations"], "summary": "Analyze repository recommendations through the recommendation service", "parameters": [{"$ref": "#/components/parameters/RepositoryID"}], "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecommendationAnalyzeRequest"}}}}, "responses": {"200": {"description": "Recommendation report"}, "400": {"$ref": "#/components/responses/BadRequest"}, "422": {"$ref": "#/components/responses/ValidationError"}, "503": {"description": "Recommendation service is not configured or unavailable"}}}},
    "/repositories/{id}/recommendations/status": {"get": {"tags": ["recommendations"], "summary": "Get recommendation counters", "parameters": [{"$ref": "#/components/parameters/RepositoryID"}], "responses": {"200": {"description": "Counters"}, "404": {"$ref": "#/components/responses/NotFound"}}}},
    "/repositories/{id}/recommendations/summary": {"get": {"tags": ["recommendations"], "summary": "Get recommendation summary", "parameters": [{"$ref": "#/components/parameters/RepositoryID"}], "responses": {"200": {"description": "Summary"}, "404": {"$ref": "#/components/responses/NotFound"}}}},
    "/repositories/{id}/recommendations": {"get": {"tags": ["recommendations"], "summary": "List recommendations", "parameters": [{"$ref": "#/components/parameters/RepositoryID"}], "responses": {"200": {"description": "Recommendations"}, "404": {"$ref": "#/components/responses/NotFound"}}}},
    "/recommendations/{id}/close": {"patch": {"tags": ["recommendations"], "summary": "Close recommendation", "parameters": [{"$ref": "#/components/parameters/RecommendationID"}], "responses": {"200": {"description": "Closed"}, "404": {"$ref": "#/components/responses/NotFound"}}}},
    "/recommendations/{id}": {"delete": {"tags": ["recommendations"], "summary": "Delete recommendation", "parameters": [{"$ref": "#/components/parameters/RecommendationID"}], "responses": {"204": {"description": "Deleted"}, "404": {"$ref": "#/components/responses/NotFound"}}}}
  },
  "components": {
    "parameters": {
      "TaskID": {"name": "taskId", "in": "path", "required": true, "schema": {"type": "string"}},
      "ConnectionID": {"name": "id", "in": "path", "required": true, "schema": {"type": "string"}},
      "IssueID": {"name": "id", "in": "path", "required": true, "schema": {"type": "string"}},
      "RepositoryID": {"name": "id", "in": "path", "required": true, "schema": {"type": "string"}},
      "RecommendationID": {"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}
    },
    "responses": {
      "BadRequest": {"description": "Malformed JSON", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Problem"}}}},
      "NotFound": {"description": "Resource not found", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Problem"}}}},
      "Unauthorized": {"description": "Authentication or GitFlame connection is required", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Problem"}}}},
      "ValidationError": {"description": "Invalid input or workflow state", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Problem"}}}}
    },
    "schemas": {
      "Repository": {"type": "object", "required": ["id", "default_branch"], "properties": {"id": {"type": "string"}, "name": {"type": "string"}, "default_branch": {"type": "string"}, "commit_sha": {"type": "string"}, "web_url": {"type": "string"}}},
      "AppUser": {"type": "object", "required": ["id", "gitflame_user_id", "username"], "properties": {"id": {"type": "string"}, "gitflame_user_id": {"type": "string"}, "username": {"type": "string"}, "created_at": {"type": "string", "format": "date-time"}, "updated_at": {"type": "string", "format": "date-time"}}},
      "GitFlameConnectionRequest": {"type": "object", "required": ["access_token"], "properties": {"access_token": {"type": "string", "format": "password"}, "repository": {"$ref": "#/components/schemas/Repository"}, "repo_url": {"type": "string", "description": "GitFlame repository URL, for example https://gitflametest.ru/owner/repo/code. Required when repository.id is omitted."}, "default_branch": {"type": "string"}, "scopes": {"type": "array", "items": {"type": "string"}}, "token_expires_at": {"type": "string", "format": "date-time"}}},
      "GitFlameConnection": {"type": "object", "required": ["id", "user_id", "repository", "token_status"], "properties": {"id": {"type": "string"}, "user_id": {"type": "string"}, "repository": {"$ref": "#/components/schemas/Repository"}, "repo_url": {"type": "string"}, "default_branch": {"type": "string"}, "token_last4": {"type": "string"}, "token_status": {"type": "string", "enum": ["active", "invalid", "expired", "revoked", "reauth_required"]}, "scopes": {"type": "array", "items": {"type": "string"}}, "token_expires_at": {"type": "string", "format": "date-time"}, "last_validated_at": {"type": "string", "format": "date-time"}, "last_used_at": {"type": "string", "format": "date-time"}, "revoked_at": {"type": "string", "format": "date-time"}, "created_at": {"type": "string", "format": "date-time"}, "updated_at": {"type": "string", "format": "date-time"}}},
      "GitFlameTreeEntry": {"type": "object", "required": ["path", "type"], "properties": {"path": {"type": "string"}, "type": {"type": "string", "enum": ["file", "dir"]}}},
      "Issue": {"type": "object", "required": ["id", "title", "body", "author"], "properties": {"id": {"type": "string"}, "title": {"type": "string"}, "body": {"type": "string"}, "author": {"type": "string"}}},
      "RepositoryFile": {"type": "object", "required": ["path"], "properties": {"path": {"type": "string"}, "content": {"type": "string", "description": "Raw file content. May be omitted or empty for authenticated GitFlame connection requests; backend will fetch it before Agent Engine calls."}, "type": {"type": "string", "enum": ["file", "blob", "dir", "tree"], "description": "Optional tree entry type. Directories are ignored when backend hydrates path-only repository files."}}},
      "IssueAnalyzeRequest": {"type": "object", "required": ["repository", "issue", "yaml_config", "repository_files"], "properties": {"repository": {"$ref": "#/components/schemas/Repository"}, "issue": {"$ref": "#/components/schemas/Issue"}, "yaml_config": {"type": "string"}, "repository_files": {"type": "array", "minItems": 1, "description": "Can contain full {path, content} objects, or path-only selected files when the request includes a valid CodePilot session cookie for a saved GitFlame connection.", "items": {"$ref": "#/components/schemas/RepositoryFile"}}, "repository_context": {"type": "array", "deprecated": true, "items": {"type": "string"}}, "metadata": {"type": "object", "additionalProperties": true}}},
      "GitFlameIssueWebhook": {"type": "object", "required": ["repository", "issue"], "properties": {"event": {"type": "string"}, "action": {"type": "string"}, "repository": {"$ref": "#/components/schemas/Repository"}, "issue": {"$ref": "#/components/schemas/Issue"}, "commit_sha": {"type": "string"}, "ref": {"type": "string"}, "yaml_config": {"type": "string"}, "repository_files": {"type": "array", "items": {"$ref": "#/components/schemas/RepositoryFile"}}, "metadata": {"type": "object", "additionalProperties": true}}},
      "IssueAnalyzeResponse": {"type": "object", "required": ["session_id", "task_id", "status", "status_url"], "properties": {"session_id": {"type": "string"}, "task_id": {"type": "string"}, "issue_id": {"type": "string"}, "repository_id": {"type": "string"}, "status": {"type": "string", "enum": ["queued"]}, "status_url": {"type": "string"}}},
      "ApprovePlanRequest": {"type": "object", "properties": {"plan_markdown": {"type": "string", "description": "Optional edited plan.md. When present, backend validates and uses this exact final plan for code generation."}}},
      "RecommendationAnalyzeRequest": {"type": "object", "required": ["repository", "yaml_config", "repository_files"], "properties": {"repository": {"$ref": "#/components/schemas/Repository"}, "yaml_config": {"type": "string"}, "repository_files": {"type": "array", "minItems": 1, "items": {"$ref": "#/components/schemas/RepositoryFile"}}, "repository_context": {"type": "array", "deprecated": true, "items": {"type": "string"}}}},
      "TaskError": {"type": "object", "properties": {"http_status": {"type": "integer", "enum": [400,404,422,502,503,504]}, "code": {"type": "string"}, "detail": {"type": "string"}}},
      "AgentTask": {"type": "object", "required": ["task_id", "session_id", "issue_id", "type", "status", "attempt"], "properties": {"task_id": {"type": "string"}, "session_id": {"type": "string"}, "issue_id": {"type": "string"}, "type": {"type": "string", "enum": ["initial_plan", "plan_revision", "code_generation"]}, "status": {"type": "string", "enum": ["queued", "processing", "completed", "failed"]}, "attempt": {"type": "integer", "minimum": 1}, "plan_markdown": {"type": "string"}, "tool_execution_summary": {"type": "string"}, "relevant_files": {"type": "array", "items": {"type": "object", "properties": {"path": {"type": "string"}, "reason": {"type": "string"}, "create": {"type": "boolean"}}}}, "model": {"type": "string"}, "usage": {"type": "object", "properties": {"prompt_tokens": {"type": "integer"}, "completion_tokens": {"type": "integer"}, "total_tokens": {"type": "integer"}, "tool_calls": {"type": "integer"}, "reasoning_chars": {"type": "integer"}, "generation_time_seconds": {"type": "number"}}}, "error": {"$ref": "#/components/schemas/TaskError"}, "generated_files_contract": {"$ref": "#/components/schemas/GeneratedFilesContract"}}},
      "GeneratedFilesContract": {"type": "object", "required": ["branch_name", "files", "commit_message", "pr_title", "reviewer"], "properties": {"request_id": {"type": "string"}, "task_id": {"type": "string"}, "summary": {"type": "string"}, "branch_name": {"type": "string"}, "base_branch": {"type": "string"}, "files": {"type": "array", "items": {"$ref": "#/components/schemas/GeneratedFileOperation"}}, "commit_message": {"type": "string"}, "pr_title": {"type": "string"}, "reviewer": {"type": "string"}, "apply_status": {"type": "string", "enum": ["applied", "failed"]}, "commit_sha": {"type": "string"}, "pull_request_id": {"type": "string"}, "pull_request_url": {"type": "string"}, "apply_error": {"type": "string"}, "applied_at": {"type": "string", "format": "date-time"}}},
      "GeneratedFileOperation": {"type": "object", "required": ["action", "path", "explanation"], "properties": {"action": {"type": "string", "enum": ["create", "modify", "delete"]}, "path": {"type": "string"}, "content": {"type": "string"}, "diff": {"type": "string"}, "explanation": {"type": "string"}, "status": {"type": "string"}, "validation_error": {"type": "string"}}},
      "RecommendationCard": {"type": "object", "required": ["id", "severity", "file", "problem", "suggestion", "state"], "properties": {"id": {"type": "string"}, "severity": {"type": "string", "enum": ["low", "medium", "high"]}, "category": {"type": "string"}, "file": {"type": "string"}, "line": {"type": "integer", "minimum": 1}, "problem": {"type": "string"}, "suggestion": {"type": "string"}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "state": {"type": "string", "enum": ["open", "closed"]}}},
      "Problem": {"type": "object", "required": ["status", "code", "detail"], "properties": {"status": {"type": "integer"}, "code": {"type": "string"}, "detail": {"type": "string"}}}
    }
  }
}
