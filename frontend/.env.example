# --------------------------------------------------------------------------
# Frontend configuration  (Sprint 5 / Version 5)
# --------------------------------------------------------------------------
# By default (no .env file, or VITE_API_BASE empty) the app runs in MOCK mode:
# all data comes from an in-memory mock and NO backend is required. The mock
# simulates the full Sprint 5 flow — the secure GitFlame connection handshake,
# the async plan/code tasks, and the apply-to-GitFlame step — so it is the mode
# used for the demo, screenshots and GIFs when the stack is not running.
#
# To connect the demo UI to the real Go backend, copy this file to ".env" and
# set VITE_API_BASE. With the Vite dev proxy, "/api" is forwarded to
# http://localhost:8000 automatically, so the recommended value is:
#
#   VITE_API_BASE=/api
#
# If you run the backend somewhere else, you can point at it directly, e.g.:
#   VITE_API_BASE=http://localhost:8000
#
# In Docker (see Dockerfile) the build is baked with VITE_API_BASE=/api and
# nginx proxies /api/ -> backend:8000, so the container always runs in live mode.
#
# COOKIES / SESSION (Sprint 5): in live mode the frontend authenticates with the
# backend's HttpOnly `codepilot_session` cookie. Every request is sent with
# credentials:'include'. Because the frontend and backend are served same-origin
# (nginx proxies /api/ to the backend), no extra CORS setup is needed. If you
# ever serve them on different origins, the backend must allow credentials and
# echo the exact Origin, and — on plain HTTP — the backend must run with
# SESSION_COOKIE_SECURE=false (already the default on the VM). On HTTPS set
# SESSION_COOKIE_SECURE=true.
# --------------------------------------------------------------------------

VITE_API_BASE=

# Where CodePilot is deployed (used to render the webhook URL to register in
# GitFlame). Defaults to the team VM. Override if you deploy elsewhere.
# VITE_DEPLOY_BASE=http://10.93.27.34
